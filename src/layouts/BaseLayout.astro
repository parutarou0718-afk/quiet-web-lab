---
import AdSenseHead from "@/components/AdSenseHead.astro";
import Analytics from "@/components/Analytics.astro";
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import PromptCartDrawer from "@/components/PromptCartDrawer.astro";
import { canonicalUrl, siteConfig } from "@/config/site";
import type { Locale, RouteKey } from "@/data/i18n";
import { localeLabels, routeAlternates } from "@/data/i18n";
import "@/styles/global.css";

interface Props {
  title: string;
  description: string;
  canonicalPath: string;
  image?: string;
  showPromptCart?: boolean;
  robots?: string;
  locale?: Locale;
  routeKey?: RouteKey;
}

const {
  title,
  description,
  canonicalPath,
  image = "/images/recipes/example-01.webp",
  showPromptCart = true,
  robots,
  locale = "en",
  routeKey
} = Astro.props;
const pageTitle = `${title} | ${siteConfig.siteName}`;
const canonical = canonicalUrl(canonicalPath);
const imageUrl = canonicalUrl(image);
const alternates = routeKey ? routeAlternates(routeKey) : null;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    {robots ? <meta name="robots" content={robots} /> : null}
    <link rel="canonical" href={canonical} />
    {
      alternates
        ? Object.entries(alternates).map(([alternateLocale, path]) => (
            <link rel="alternate" hreflang={alternateLocale} href={canonicalUrl(path)} title={localeLabels[alternateLocale as Locale]} />
          ))
        : null
    }
    {alternates ? <link rel="alternate" hreflang="x-default" href={canonicalUrl(alternates.en)} /> : null}
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:type" content="website" />
    <AdSenseHead />
    <Analytics />
  </head>
  <body>
    <Header locale={locale} routeKey={routeKey} />
    <main>
      <slot />
    </main>
    {showPromptCart ? <PromptCartDrawer /> : null}
    <Footer locale={locale} />
  </body>
</html>


