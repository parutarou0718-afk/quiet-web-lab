---
import { siteConfig } from "@/config/site";
import type { Locale } from "@/data/i18n";
import { localizedPath } from "@/data/i18n";

interface Props {
  locale?: Locale;
}

const { locale = "en" } = Astro.props;
const copy = {
  text: "Practical AI workflows, prompt systems, and lightweight automation tools.",
  tools: "Tools",
  workflows: "Workflows",
  services: "Services",
  products: "Products",
  cases: "Case Studies",
  recipes: "Recipes",
  guides: "Guides",
  lora: "LoRA",
  contact: "Contact",
  privacy: "Privacy",
  terms: "Terms",
  disclaimer: "Disclaimer"
};
---

<footer class="site-footer">
  <p>© {new Date().getFullYear()} {siteConfig.siteName}. {copy.text}</p>
  <nav aria-label="Footer navigation">
    <a href={localizedPath("/tools/", locale)}>{copy.tools}</a>
    <a href={localizedPath("/workflows/", locale)}>{copy.workflows}</a>
    <a href={localizedPath("/services/", locale)}>{copy.services}</a>
    <a href={localizedPath("/products/", locale)}>{copy.products}</a>
    <a href={localizedPath("/case-studies/", locale)}>{copy.cases}</a>
    <a href={localizedPath("/recipes/", locale)}>{copy.recipes}</a>
    <a href={localizedPath("/guides/", locale)}>{copy.guides}</a>
    <a href={localizedPath("/lora/", locale)}>{copy.lora}</a>
    <a href={localizedPath("/contact/", locale)}>{copy.contact}</a>
    <a href={localizedPath("/privacy/", locale)}>{copy.privacy}</a>
    <a href={localizedPath("/terms/", locale)}>{copy.terms}</a>
    <a href={localizedPath("/disclaimer/", locale)}>{copy.disclaimer}</a>
  </nav>
</footer>
