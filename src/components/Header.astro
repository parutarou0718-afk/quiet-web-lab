---
import { siteConfig } from "@/config/site";
import type { Locale, RouteKey } from "@/data/i18n";
import { localeNames, localizedPath, navLabels, navRoutes, routeFromPath } from "@/data/i18n";

interface Props {
  locale?: Locale;
  routeKey?: RouteKey;
}

const { locale = "en", routeKey = routeFromPath(Astro.url.pathname) } = Astro.props;
const labels = navLabels[locale];
---

<header class="site-header">
  <a class="brand" href={localizedPath("/", locale)} aria-label={`${siteConfig.siteName} home`}>
    <span class="brand-mark">QW</span>
    <span>{siteConfig.siteName}</span>
  </a>
  <nav class="site-nav" aria-label="Main navigation">
    {navRoutes.map((item) => <a href={localizedPath(item.route, locale)}>{labels[item.key]}</a>)}
    <span class="language-switcher" aria-label="Language switcher">
      {(["en", "zh", "ja"] as Locale[]).map((targetLocale) => (
        <a class={targetLocale === locale ? "is-active" : ""} href={localizedPath(routeKey, targetLocale)}>{localeNames[targetLocale]}</a>
      ))}
    </span>
  </nav>
</header>
