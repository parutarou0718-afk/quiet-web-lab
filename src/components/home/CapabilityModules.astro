---
import { capabilities } from "@/data/capabilities";
---

<section class="content-section">
  <div class="section-heading section-heading--split">
    <div>
      <p class="eyebrow">Capabilities</p>
      <h2>What We Build</h2>
    </div>
    <p class="muted">AI implementation is broader than image prompts. These modules show how text, images, documents, and automation can become practical systems.</p>
  </div>
  <div class="capability-grid">
    {capabilities.map((item) => (
      <article class="solution-card">
        <div class="card-meta"><span>{item.category}</span><span>{item.status}</span></div>
        <h3>{item.title}</h3>
        <p>{item.description}</p>
        <ul class="compact-list">
          {item.useCases.map((useCase) => <li>{useCase}</li>)}
        </ul>
        <a class="text-link" href={item.url}>{item.cta}</a>
      </article>
    ))}
  </div>
</section>
