---
type Locale = "en" | "zh" | "ja";

interface Props {
  locale?: Locale;
}

const { locale = "en" } = Astro.props;

const githubUrl = "https://github.com/parutarou0718-afk/perception-notification-system-design";
const coverImage = "/images/covers/ai-development-guide-cover.webp";

const copy = {
  en: {
    eyebrow: "AI Implementation Guide",
    title: "A practical guide to building local AI workflow tools without wasting tokens.",
    lead: "Based on a Windows FAX monitoring tool: how to define requirements before coding, keep OCR usable on office PCs, and turn repeated lessons into reusable Codex Skills.",
    github: "Open GitHub guide",
    posts: [
      {
        title: "Define product behavior before asking the coding agent to build.",
        body: "Buttons, unread states, recovery rules, and main-screen data all need clear decisions. Otherwise the agent spends tokens guessing product logic instead of implementing it."
      },
      {
        title: "Design for the computer that will actually run the tool.",
        body: "OCR, shared folders, historical scans, and UI-thread work can overload a normal office PC. Treat performance limits as part of the guide, not a late bug fix."
      },
      {
        title: "Use Skills to preserve engineering rules, not to replace thinking.",
        body: "The reusable guide captures read-only source folders, incremental monitoring, OCR fallback, visible notifications, and reversible states for future automation projects."
      }
    ]
  },
  zh: {
    eyebrow: "AI 落地开发指南",
    title: "一套面向本地 AI 工作流工具的开发指南。",
    lead: "基于 Windows FAX 监听工具整理：先定需求再写代码，让 OCR 在办公电脑上能跑，并把反复踩过的工程规则沉淀成可复用的 Codex Skill。",
    github: "打开 GitHub 指南仓库",
    posts: [
      {
        title: "先固定产品行为，再让编码 Agent 开始实现。",
        body: "按钮怎么响应、未读何时清除、归档能否恢复、主页面展示文件还是业务记录，这些都要先讲清楚。否则 Token 会花在反复猜产品逻辑上。"
      },
      {
        title: "按真正要运行的办公电脑来设计。",
        body: "OCR、共享目录、历史文件扫描和 UI 主线程都会影响体验。性能限制应该写进开发指南里，而不是等软件做完以后再补救。"
      },
      {
        title: "Skill 是工程规则库，不是替你思考的神器。",
        body: "这套指南固化了只读上游目录、增量监听、OCR 失败兜底、可见通知、可恢复状态等规则，方便以后复用到新的自动化工具里。"
      }
    ]
  },
  ja: {
    eyebrow: "AI 実装ガイド",
    title: "ローカル AI ワークフローツールを作るための実践ガイド。",
    lead: "Windows FAX 監視ツールをもとに、実装前の要件整理、オフィス PC で動く OCR 設計、Codex Skill として再利用できる開発ルールをまとめました。",
    github: "GitHub ガイドを開く",
    posts: [
      {
        title: "コーディング前に、製品としての挙動を決める。",
        body: "ボタンの動き、未読状態、復元ルール、メイン画面に表示する情報を先に決めることで、Agent が推測にトークンを使い続ける状況を避けられます。"
      },
      {
        title: "実際に使うオフィス PC を基準に設計する。",
        body: "OCR、共有フォルダ、過去ファイルの走査、UI スレッド上の処理は、普通の業務 PC ではすぐ問題になります。性能条件もガイドの一部です。"
      },
      {
        title: "Skill は魔法ではなく、開発ルールを残すための仕組み。",
        body: "読み取り専用の入力、増分監視、OCR 失敗時の確認、見える通知、復元できる状態管理を、次の自動化ツールでも使える形にしています。"
      }
    ]
  }
}[locale];
---

<section class="content-section dev-guide">
  <div class="section-heading section-heading--split">
    <div>
      <p class="eyebrow">{copy.eyebrow}</p>
      <h2>{copy.title}</h2>
    </div>
    <p class="muted">{copy.lead}</p>
  </div>

  <div class="dev-guide-layout">
    <img class="dev-guide-cover" src={coverImage} alt="" loading="lazy" />
    <div class="dev-guide-content">
      <div class="article-grid">
        {copy.posts.map((post, index) => (
          <article class="article-card">
            <span class="category-badge">{index + 1}</span>
            <h3>{post.title}</h3>
            <p>{post.body}</p>
          </article>
        ))}
      </div>
      <div class="hero-actions section-actions">
        <a class="button" href={githubUrl} target="_blank" rel="noopener noreferrer">{copy.github}</a>
      </div>
    </div>
  </div>
</section>
