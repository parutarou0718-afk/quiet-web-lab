---
import RecipeCard from "@/components/RecipeCard.astro";
import type { CollectionEntry } from "astro:content";
import type { PromptRecipe } from "@/lib/promptCart";

interface Props {
  guides: CollectionEntry<"guides">[];
  recipes: PromptRecipe[];
}

const { guides, recipes } = Astro.props;
---

<section class="content-section">
  <div class="section-heading section-heading--split">
    <div>
      <p class="eyebrow">Learning Library</p>
      <h2>Latest Guides and Prompt Recipes</h2>
    </div>
    <p class="muted">Guides, recipes, and LoRA notes remain available as supporting knowledge below the company-level positioning.</p>
  </div>
  <div class="article-grid">
    {guides.map((guide) => (
      <a class="article-card" href={`/guides/${guide.slug}/`}>
        {guide.data.coverImage ? <img class="article-card-media" src={guide.data.coverImage} alt="" loading="lazy" /> : null}
        <span class="category-badge">Guide</span>
        <h3>{guide.data.title}</h3>
        <p>{guide.data.description}</p>
      </a>
    ))}
  </div>
  <div class="recipe-grid home-recipe-strip">
    {recipes.slice(0, 3).map((recipe) => <RecipeCard recipe={recipe} locale="en" />)}
  </div>
  <div class="hero-actions section-actions">
    <a class="button secondary" href="/guides/">Browse Guides</a>
    <a class="button secondary" href="/recipes/">Browse Recipes</a>
    <a class="button secondary" href="/lora/">LoRA Notes</a>
  </div>
</section>

