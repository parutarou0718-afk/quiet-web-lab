---
type Locale = "en" | "zh" | "ja";

interface Props {
  locale?: Locale;
}

const { locale = "en" } = Astro.props;

const githubUrl = "https://github.com/parutarou0718-afk/perception-notification-system-design";
const coverImage = "/images/covers/ai-development-review-cover.webp";

const copy = {
  en: {
    eyebrow: "Development Notes",
    title: "A real postmortem from building a Windows FAX monitoring tool with AI.",
    lead: "Three practical notes on where AI coding burns tokens, why local OCR performance matters, and how reusable Codex Skills can prevent repeated engineering mistakes.",
    github: "Open GitHub repository",
    posts: [
      {
        title: "The biggest token drain was not writing code.",
        body: "The expensive part was letting the coding agent guess product decisions: button behavior, unread state, recovery rules, and whether the main screen should show files or business records."
      },
      {
        title: "Running locally is not the same as running on an office PC.",
        body: "OCR, shared folders, historical scans, and UI-thread work can turn a simple desktop tool into a frozen app. Performance has to be tested before the architecture is finished."
      },
      {
        title: "The Skill is a guardrail, not a magic token saver.",
        body: "The reusable design captures safety boundaries, incremental monitoring, OCR fallback, notifications, and reversible states so the same engineering mistakes are less likely to repeat."
      }
    ]
  },
  zh: {
    eyebrow: "AI 开发复盘",
    title: "一次 Windows FAX 监听工具的真实开发复盘。",
    lead: "三篇短文记录了 AI 编程最烧 Token 的地方、本地 OCR 性能坑，以及为什么最后把经验整理成 Codex Skill。",
    github: "查看 GitHub 仓库",
    posts: [
      {
        title: "最烧 Token 的地方，可能根本不是写代码。",
        body: "真正浪费的是让编码 Agent 反复猜产品细节：按钮行为、未读状态、归档能否撤回、主页面到底展示文件还是业务记录。"
      },
      {
        title: "能在我电脑运行，不代表能在客户电脑运行。",
        body: "OCR、共享目录、历史扫描和 UI 主线程很容易把桌面工具拖死。性能测试必须尽早放到目标办公电脑上做。"
      },
      {
        title: "Skill 是护栏，不是省 Token 神器。",
        body: "这套规范固化了只读共享目录、增量监听、OCR 兜底、通知语义和可恢复状态，防止同类工程坑反复发生。"
      }
    ]
  },
  ja: {
    eyebrow: "開発ふりかえり",
    title: "Windows FAX 監視ツールをAIと作った実際の開発メモ。",
    lead: "AIコーディングでトークンを消費しやすい場面、ローカルOCRの性能問題、そして経験をCodex Skillとして再利用する理由をまとめました。",
    github: "GitHubリポジトリを見る",
    posts: [
      {
        title: "一番トークンを使ったのは、コードを書く部分ではありませんでした。",
        body: "ボタンの挙動、未読状態、取り消し可能な操作、メイン画面に何を出すかなど、製品判断をAIに推測させたことが一番の手戻りでした。"
      },
      {
        title: "自分のPCで動くことは、顧客のPCで動くこととは違います。",
        body: "OCR、共有フォルダ、過去ファイルの走査、UIスレッド上の処理は、普通の業務PCではすぐ問題になります。"
      },
      {
        title: "Skillは万能な節約術ではなく、再発防止のためのガードレールです。",
        body: "共有フォルダの安全境界、増分監視、OCR失敗時の確認、通知、復元できる状態管理を、次の開発でも使える形にしました。"
      }
    ]
  }
}[locale];
---

<section class="content-section dev-review">
  <div class="section-heading section-heading--split">
    <div>
      <p class="eyebrow">{copy.eyebrow}</p>
      <h2>{copy.title}</h2>
    </div>
    <p class="muted">{copy.lead}</p>
  </div>

  <div class="dev-review-layout">
    <img class="dev-review-cover" src={coverImage} alt="" loading="lazy" />
    <div class="dev-review-content">
      <div class="article-grid">
        {copy.posts.map((post, index) => (
          <article class="article-card">
            <span class="category-badge">{index + 1}</span>
            <h3>{post.title}</h3>
            <p>{post.body}</p>
          </article>
        ))}
      </div>
      <div class="hero-actions section-actions">
        <a class="button" href={githubUrl} target="_blank" rel="noopener noreferrer">{copy.github}</a>
      </div>
    </div>
  </div>
</section>
