---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";

const entries = await getCollection("workflows");
---

<BaseLayout title="Workflow Solutions" description="Demo AI workflows for prompt systems, ComfyUI samples, OCR, automation, and static publishing." canonicalPath="/workflows/" locale="en" routeKey="/workflows/">
  <section class="content-section">
    <div class="section-heading">
      <p class="eyebrow">Workflows</p>
      <h1>Workflow solutions for repeatable AI production.</h1>
      <p class="lead">Each workflow describes the problem, solution, tools involved, output, and business use.</p>
    </div>
    <div class="article-grid">
      {entries.map((entry) => (
        <a class="article-card" href={`/workflows/${entry.slug}/`}>
          <span class="category-badge">{entry.data.status}</span>
          <h3>{entry.data.title}</h3>
          <p>{entry.data.description}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
