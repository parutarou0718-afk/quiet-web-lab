---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import HeroSection from "@/components/home/HeroSection.astro";
import CapabilityModules from "@/components/home/CapabilityModules.astro";
import FeaturedTools from "@/components/home/FeaturedTools.astro";
import ServicesOverview from "@/components/home/ServicesOverview.astro";
import DemoCaseStudies from "@/components/home/DemoCaseStudies.astro";
import ProductsPreview from "@/components/home/ProductsPreview.astro";
import LatestGuides from "@/components/home/LatestGuides.astro";
import ContactCTA from "@/components/home/ContactCTA.astro";
import AdSlot from "@/components/AdSlot.astro";
import { getCmsRecipes } from "@/lib/cms";

const guides = [...await getCollection("guides")].sort((a, b) => Number(b.data.date) - Number(a.data.date)).slice(0, 3);
const recipes = await getCmsRecipes();
---

<BaseLayout
  title="AI Implementation Studio for Workflows, Prompt Systems, and Automation Tools"
  description="Smart Prompt App builds practical AI workflows, prompt systems, automation templates, and lightweight web products for creators, students, small teams, and businesses."
  canonicalPath="/"
  showPromptCart={false}
  locale="en"
  routeKey="/"
>
  <HeroSection />
  <CapabilityModules />
  <FeaturedTools />
  <AdSlot />
  <ServicesOverview />
  <DemoCaseStudies />
  <ProductsPreview />
  <LatestGuides guides={guides} recipes={recipes} />
  <ContactCTA />
</BaseLayout>
