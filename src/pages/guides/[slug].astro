---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const guides = await getCollection("guides");
  return guides.map((guide) => ({ params: { slug: guide.slug }, props: { guide } }));
}

const { guide } = Astro.props;
const { Content } = await guide.render();
---

<BaseLayout title={guide.data.title} description={guide.data.description} canonicalPath={`/guides/${guide.slug}/`} image={guide.data.coverImage} locale="en" routeKey="/guides/">
  <article class="content-section article-body">
    <div class="section-heading">
      <p class="eyebrow">{guide.data.category}</p>
      <h1>{guide.data.title}</h1>
      <p class="lead">{guide.data.description}</p>
      <time datetime={guide.data.date.toISOString()}>{guide.data.date.toISOString().slice(0, 10)}</time>
    </div>
    {guide.data.coverImage ? <img class="news-hero-image" src={guide.data.coverImage} alt="" /> : null}
    <Content />
  </article>
</BaseLayout>
