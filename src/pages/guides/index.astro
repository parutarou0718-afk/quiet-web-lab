---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCmsGuides } from "@/lib/cms";

const guides = await getCmsGuides();
---

<BaseLayout title="Prompt Writing Guides" description="Practical AI image prompt writing guides for structure, poses, clothing, camera, negative prompts, and iteration." canonicalPath="/guides/" locale="en" routeKey="/guides/">
  <section class="content-section">
    <div class="section-heading">
      <p class="eyebrow">Guides</p>
      <h1>Learn prompt writing one visual decision at a time.</h1>
      <p class="lead">These guides explain prompt structure in plain English and connect directly to the recipe builder workflow.</p>
    </div>
    <div class="article-grid">
      {guides.map((guide) => (
        <a class="article-card" href={`/guides/${guide.slug}/`}>
          {guide.data.coverImage ? <img class="article-card-media" src={guide.data.coverImage} alt="" loading="lazy" /> : null}
          <span class="category-badge">{guide.data.category}</span>
          <h3>{guide.data.title}</h3>
          <p>{guide.data.description}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
