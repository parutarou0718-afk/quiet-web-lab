---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { latestNews } from "@/data/news";
---

<BaseLayout
  title="AI Image Generation News and Updates"
  description="Daily notes about AI image generation prompts, model tests, ComfyUI workflows, and prompt library updates."
  canonicalPath="/news/"
>
  <section class="content-section">
    <div class="section-heading">
      <p class="eyebrow">News</p>
      <h1>Daily AI image generation notes, tests, and prompt updates.</h1>
      <p class="lead">
        Short practical updates about prompt experiments, model comparisons, ComfyUI sample batches, and changes to the
        prompt library.
      </p>
    </div>
    <div class="news-list">
      {latestNews.map((post) => (
        <a class="news-card" href={`/news/${post.slug}/`}>
          {post.heroImage ? <img src={post.heroImage} alt="" loading="lazy" /> : null}
          <div>
            <span class="category-badge">{post.category}</span>
            <time datetime={post.date}>{post.date}</time>
            <h2>{post.title}</h2>
            <p>{post.description}</p>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
