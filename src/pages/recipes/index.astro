---
import RecipeCard from "@/components/RecipeCard.astro";
import { recipePageCopy } from "@/data/recipePages";
import { getCmsRecipes } from "@/lib/cms";
import BaseLayout from "@/layouts/BaseLayout.astro";

const copy = recipePageCopy.en;
const recipes = await getCmsRecipes();
---

<BaseLayout title={copy.title} description={copy.description} canonicalPath="/recipes/" locale="en" routeKey="/recipes/">
  <section class="content-section">
    <div class="section-heading">
      <p class="eyebrow">{copy.eyebrow}</p>
      <h1>{copy.h1}</h1>
      <p class="lead">{copy.lead}</p>
    </div>
    <div class="recipe-grid">
      {recipes.map((recipe) => <RecipeCard recipe={recipe} locale="en" />)}
    </div>
  </section>
</BaseLayout>
