---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { productTemplates } from "@/data/products";
---

<BaseLayout title="AI Products and Templates" description="Future AI prompt packs, research templates, workflow checklists, LoRA captioning kits, static site templates, and n8n workflow templates." canonicalPath="/products/" locale="en" routeKey="/products/">
  <section class="content-section">
    <div class="section-heading">
      <p class="eyebrow">Products</p>
      <h1>Products and templates for practical AI workflows.</h1>
      <p class="lead">These digital products are planned or in preview. No payment flow is enabled yet; use Contact or Waitlist if you want to discuss a specific template.</p>
      <div class="hero-actions">
        <a class="button" href="/contact/">Contact / Waitlist</a>
      </div>
    </div>
    <div class="article-grid">
      {productTemplates.map((product) => (
        <article class="article-card">
          <span class="category-badge">{product.status}</span>
          <h3>{product.title}</h3>
          <p>{product.description}</p>
          <p><strong>Included items:</strong> {product.includedItems.join(", ")}</p>
          <p><strong>Target users:</strong> {product.targetUsers.join(", ")}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
