---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="新闻后台"
  description="用于编写 Quiet Web Lab 新闻更新的本地编辑后台。"
  canonicalPath="/zh/admin/news/"
  showPromptCart={false}
  robots="noindex,nofollow"
  locale="zh"
  routeKey="/admin/news/"
>
  <section class="hero admin-hero">
    <div>
      <p class="eyebrow">本地后台</p>
      <h1>新闻更新工作台</h1>
      <p class="lead">这里用于写每日更新、保存本地草稿、预览文章结构，并生成可以放进 `src/data/news.ts` 的新闻数据。</p>
      <div class="hero-actions">
        <a class="button" href="/zh/news/">查看新闻</a>
        <a class="button secondary" href="/admin/news/">打开完整编辑器</a>
      </div>
    </div>
  </section>
  <section class="content-section">
    <iframe class="admin-embed" src="/admin/news/" title="News admin editor"></iframe>
  </section>
</BaseLayout>
