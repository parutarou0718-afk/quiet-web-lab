---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="新闻后台"
  description="Smart Prompt App 新闻编辑入口。"
  canonicalPath="/zh/admin/news/"
  showPromptCart={false}
  robots="noindex,nofollow"
  locale="zh"
  routeKey="/admin/news/"
>
  <section class="hero admin-hero">
    <div>
      <p class="eyebrow">本地后台</p>
      <h1>新闻更新工作台</h1>
      <p class="lead">这里是给站长使用的新闻编辑入口。正文可以自己写中文或日文，但发布表单目前使用英文结构，方便生成统一 JSON。</p>
      <div class="hero-actions">
        <a class="button" href="/zh/news/">查看新闻</a>
        <a class="button secondary" href="/admin/news/">打开完整编辑器</a>
      </div>
    </div>
  </section>
  <section class="content-section">
    <iframe class="admin-embed" src="/admin/news/" title="News admin editor"></iframe>
  </section>
</BaseLayout>
