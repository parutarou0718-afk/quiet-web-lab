---
import { localizedSlugPath, newsPageCopy } from "@/data/i18n";
import { latestNews } from "@/data/news";
import BaseLayout from "@/layouts/BaseLayout.astro";

const copy = newsPageCopy.zh;
---

<BaseLayout title={copy.title} description={copy.description} canonicalPath="/zh/news/" locale="zh" routeKey="/news/">
  <section class="content-section">
    <div class="section-heading">
      <p class="eyebrow">{copy.eyebrow}</p>
      <h1>{copy.h1}</h1>
      <p class="lead">{copy.lead}</p>
    </div>
    <div class="news-list">
      {latestNews.map((post) => (
        <a class="news-card" href={localizedSlugPath("/news/", post.slug, "zh")}>
          {post.heroImage ? <img src={post.heroImage} alt="" loading="lazy" /> : null}
          <div>
            <span class="category-badge">{post.category}</span>
            <time datetime={post.date}>{post.date}</time>
            <h2>{post.title}</h2>
            <p>{post.description}</p>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
