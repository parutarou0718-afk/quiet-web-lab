---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { localizeInternalHref, newsPageCopy } from "@/data/i18n";
import { publishedNews } from "@/data/news";

export function getStaticPaths() {
  return publishedNews.map((post) => ({
    params: { slug: post.slug },
    props: { post }
  }));
}

const { post } = Astro.props;
const copy = newsPageCopy.zh;
---

<BaseLayout title={post.title} description={post.description} canonicalPath={`/zh/news/${post.slug}/`} image={post.heroImage} locale="zh" routeKey="/news/">
  <article class="content-section news-detail">
    <div class="section-heading">
      <p class="eyebrow">{post.category}</p>
      <h1>{post.title}</h1>
      <p class="lead">{post.description}</p>
      <time datetime={post.date}>{post.date}</time>
    </div>

    {post.heroImage ? <img class="news-hero-image" src={post.heroImage} alt="" /> : null}

    <section class="prompt-block">
      <h2>{copy.takeaways}</h2>
      <ul>{post.takeaways.map((takeaway) => <li>{takeaway}</li>)}</ul>
    </section>

    <div class="article-body">
      {post.body.map((paragraph) => <p>{paragraph}</p>)}
    </div>

    <section class="content-section">
      <div class="section-heading"><h2>{copy.related}</h2></div>
      <div class="category-grid">
        {post.relatedLinks.map((link) => (
          <a class="category-card" href={localizeInternalHref(link.href, "zh")}>
            <h3>{link.label}</h3>
            <p>{copy.continue}</p>
          </a>
        ))}
      </div>
    </section>
  </article>
</BaseLayout>
