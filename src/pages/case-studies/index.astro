---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { demoCaseStudies, demoDisclaimer } from "@/data/caseStudies";
---

<BaseLayout title="Demo AI Case Studies" description="Clearly labeled demo case studies for AI prompt systems, OCR workflows, image production, learning tools, and static SEO sites." canonicalPath="/case-studies/" locale="en" routeKey="/case-studies/">
  <section class="content-section">
    <div class="section-heading">
      <p class="eyebrow">Demo Case Studies</p>
      <h1>Implementation patterns shown as demo case studies.</h1>
      <p class="lead">{demoDisclaimer}</p>
    </div>
    <div class="workflow-list">
      {demoCaseStudies.map((item) => (
        <article class="solution-card workflow-card">
          <div class="card-meta"><span>{item.category}</span><span>{item.status}</span></div>
          <h2>{item.title}</h2>
          <p>{item.description}</p>
          <dl class="info-list">
            <div><dt>Context</dt><dd>{item.context}</dd></div>
            <div><dt>Problem</dt><dd>{item.problem}</dd></div>
            <div><dt>Output</dt><dd>{item.output}</dd></div>
            <div><dt>Business value</dt><dd>{item.businessValue}</dd></div>
          </dl>
          <ul class="compact-list">
            {item.workflow.map((step) => <li>{step}</li>)}
          </ul>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
