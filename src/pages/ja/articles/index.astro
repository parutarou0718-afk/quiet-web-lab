---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Articles" description="Localized article pages are planned for this mirror site." canonicalPath="/ja/articles/" locale="ja" routeKey="/articles/">
  <section class="content-section">
    <div class="section-heading">
      <p class="eyebrow">Articles</p>
      <h1>Articles mirror is reserved.</h1>
      <p class="lead">The English article library is available now. This localized mirror will be filled after the base content is stable.</p>
      <a class="button-link" href="/articles/">Open English articles</a>
    </div>
  </section>
</BaseLayout>
