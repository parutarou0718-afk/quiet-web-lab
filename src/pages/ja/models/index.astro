---
import AdSlot from "@/components/AdSlot.astro";
import { localizedPath, modelPageCopy } from "@/data/i18n";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { comparisonImage, comparisonModels, comparisonPrompts } from "@/data/modelComparison";

const locale = "ja";
const copy = modelPageCopy[locale];
---

<BaseLayout title={copy.title} description={copy.description} canonicalPath="/ja/models/" locale={locale} routeKey="/models/">
  <section class="hero">
    <div>
      <p class="eyebrow">{copy.eyebrow}</p>
      <h1>{copy.h1}</h1>
      <p class="lead">{copy.lead}</p>
      <div class="hero-actions">
        <a class="button" href={localizedPath("/builder/", locale)}>{copy.builder}</a>
        <a class="button secondary" href={localizedPath("/recipes/", locale)}>{copy.recipes}</a>
      </div>
    </div>
  </section>

  <section class="content-section">
    <div class="section-heading">
      <h2>{copy.notes}</h2>
      <p class="muted">{copy.notesLead}</p>
    </div>
    <div class="model-grid model-grid--notes">
      {comparisonModels.map((model) => (
        <article class="model-card">
          <span class="category-badge">{model.label}</span>
          <h2>{model.name}</h2>
          <p>{model.tone}</p>
          <h3>{copy.bestFor}</h3>
          <p>{model.bestFor}</p>
        </article>
      ))}
    </div>
  </section>

  <AdSlot />

  <section class="content-section">
    <div class="section-heading">
      <h2>{copy.results}</h2>
      <p class="muted">{copy.resultsLead}</p>
    </div>
    <div class="comparison-table" aria-label="Local checkpoint comparison grid">
      <div class="comparison-corner">{copy.prompt}</div>
      {comparisonModels.map((model) => (
        <div class="comparison-model-head"><strong>{model.name}</strong><span>{model.label}</span></div>
      ))}
      {comparisonPrompts.map((prompt) => (
        <>
          <article class="comparison-prompt">
            <span class="category-badge">{prompt.id.toUpperCase()} {prompt.seedPick}</span>
            <h3>{prompt.title}</h3>
            <p>{prompt.description}</p>
          </article>
          {comparisonModels.map((model) => (
            <figure class="comparison-image">
              <img src={comparisonImage(prompt.id, model.id)} alt={`${model.name} result for ${prompt.title}`} loading="lazy" />
              <figcaption>{model.label}</figcaption>
            </figure>
          ))}
        </>
      ))}
    </div>
  </section>
</BaseLayout>
