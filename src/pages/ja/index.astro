---
import BaseLayout from "@/layouts/BaseLayout.astro";
import DevelopmentGuideFeature from "@/components/home/DevelopmentGuideFeature.astro";
import { localizedPath } from "@/data/i18n";

const locale = "ja";
---

<BaseLayout
  title="実用的なAIワークフローとプロンプトツール"
  description="Smart Prompt App は、文章作成、研究計画、メール作成、画像生成、業務自動化に使える軽量なAIツールとワークフローを提供します。"
  canonicalPath="/ja/"
  showPromptCart={false}
  locale={locale}
  routeKey="/"
>
  <section class="hero hub-hero">
    <div>
      <p class="eyebrow">Smart Prompt App</p>
      <h1>AIを、実際の作業に使える形へ。</h1>
      <p class="lead">研究計画、メール作成、画像プロンプト、ドキュメント処理、業務自動化のための、軽量で使いやすいAIワークフローとプロンプトシステムをまとめています。</p>
      <div class="hero-actions">
        <a class="button" href={localizedPath("/tools/", locale)}>ツールを見る</a>
        <a class="button secondary" href={localizedPath("/services/", locale)}>サービスを見る</a>
      </div>
    </div>
    <aside class="hero-panel hub-panel">
      <div class="stat-grid">
        <div class="stat"><strong>2</strong><span>利用可能な無料ツール</span></div>
        <div class="stat"><strong>static</strong><span>Cloudflare Pages対応</span></div>
        <div class="stat"><strong>no login</strong><span>ログイン不要</span></div>
        <div class="stat"><strong>AI</strong><span>実装向けテンプレート</span></div>
      </div>
    </aside>
  </section>

  <section class="content-section">
    <div class="section-heading section-heading--split">
      <div>
        <p class="eyebrow">Available Tools</p>
        <h2>すぐ使える無料ツール</h2>
      </div>
      <p class="muted">第一版では、研究計画とメール作成に使えるプロンプト生成ツールを公開しています。</p>
    </div>
    <div class="article-grid">
      <a class="article-card article-card--action" href="/ja/tools/research-prompt-assistant/">
        <span class="category-badge">Active</span>
        <h3>Research Prompt Assistant</h3>
        <p>曖昧な研究テーマを、AIに渡しやすい構造化プロンプトに変換します。卒論、研究質問、方法論、文献レビュー計画に便利です。</p>
        <span class="button small-button">開く</span>
      </a>
      <a class="article-card article-card--action" href="/ja/tools/email-prompt-builder/">
        <span class="category-badge">Active</span>
        <h3>Email Prompt Builder</h3>
        <p>メールの状況、相手、距離感、語調を整理して、ChatGPTなどで自然なメールを作るためのプロンプトに変換します。</p>
        <span class="button small-button">開く</span>
      </a>
      <a class="article-card article-card--action" href={localizedPath("/builder/", locale)}>
        <span class="category-badge">Available</span>
        <h3>Image Prompt Builder</h3>
        <p>画像生成用のプロンプト断片を組み合わせ、矛盾を確認しながら英語プロンプトを作れます。</p>
        <span class="button small-button">開く</span>
      </a>
    </div>
  </section>

  <DevelopmentGuideFeature locale="ja" />

  <section class="content-section">
    <div class="section-heading">
      <p class="eyebrow">What We Build</p>
      <h2>小さく始めて、実際の作業に組み込めるAIツール。</h2>
      <p class="lead">プロンプト集だけでなく、研究、文章、画像制作、ドキュメント処理、n8n自動化などに展開できる静的サイト型のAI実装テンプレートを増やしていきます。</p>
    </div>
  </section>
</BaseLayout>
