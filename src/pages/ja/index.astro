---
import AdSlot from "@/components/AdSlot.astro";
import RecipeCard from "@/components/RecipeCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { homeCopy, localizedPath, localizedSlugPath } from "@/data/i18n";
import { latestNews } from "@/data/news";
import { recipes } from "@/data/recipes";
import { siteConfig } from "@/config/site";

const locale = "ja";
const copy = homeCopy[locale];
---

<BaseLayout title={copy.title} description={siteConfig.description} canonicalPath="/ja/" showPromptCart={false} locale={locale} routeKey="/">
  <section class="hero hub-hero">
    <div>
      <p class="eyebrow">Smart Prompt App</p>
      <h1>{copy.h1}</h1>
      <p class="lead">{copy.lead}</p>
      <div class="hero-actions">
        <a class="button" href={localizedPath("/builder/", locale)}>{copy.builderCta}</a>
        <a class="button secondary" href={localizedPath("/models/", locale)}>{copy.modelCta}</a>
      </div>
    </div>
    <aside class="hero-panel hub-panel">
      <div class="stat-grid">
        <div class="stat"><strong>{recipes.length}</strong><span>{copy.recipes}</span></div>
        <div class="stat"><strong>4</strong><span>{copy.models}</span></div>
        <div class="stat"><strong>static</strong><span>{copy.static}</span></div>
        <div class="stat"><strong>local</strong><span>{copy.local}</span></div>
      </div>
    </aside>
  </section>

  <section class="content-section product-grid">
    <a class="product-card product-card--ai" href={localizedPath("/builder/", locale)}>
      <span class="eyebrow">{copy.promptBuilder}</span>
      <h2>{copy.promptBuilderTitle}</h2>
      <p>{copy.promptBuilderBody}</p>
      <span class="button">{copy.promptBuilderButton}</span>
    </a>
    <a class="product-card product-card--models" href={localizedPath("/models/", locale)}>
      <span class="eyebrow">{copy.modelGuide}</span>
      <h2>{copy.modelGuideTitle}</h2>
      <p>{copy.modelGuideBody}</p>
      <span class="button">{copy.modelGuideButton}</span>
    </a>
  </section>

  <AdSlot />

  <section class="content-section">
    <div class="section-heading">
      <h2>{copy.startHere}</h2>
      <p class="muted">{copy.startLead}</p>
    </div>
    <div class="category-grid">
      <a class="category-card" href={localizedPath("/recipes/", locale)}><h3>プロンプトレシピ</h3><p>再利用できる断片に分けられる完成例を閲覧できます。</p></a>
      <a class="category-card" href={localizedPath("/guides/", locale)}><h3>プロンプトガイド</h3><p>構造、カメラ、ネガティブ、衣装、ポーズ、反復方法を学べます。</p></a>
      <a class="category-card" href={localizedPath("/lora/", locale)}><h3>LoRA メモ</h3><p>データセット、キャプション、学習設定、テスト、整理方法をまとめます。</p></a>
    </div>
  </section>

  <section class="content-section">
    <div class="section-heading">
      <h2>{copy.latestRecipes}</h2>
      <p class="muted">{copy.latestRecipesLead}</p>
    </div>
    <div class="recipe-grid">
      {recipes.slice(0, 3).map((recipe) => <RecipeCard recipe={recipe} locale={locale} />)}
    </div>
  </section>

  <section class="content-section">
    <div class="section-heading">
      <h2>{copy.latestUpdates}</h2>
      <p class="muted">{copy.latestUpdatesLead}</p>
    </div>
    <div class="article-grid">
      {latestNews.slice(0, 3).map((post) => (
        <a class="article-card" href={localizedSlugPath("/news/", post.slug, locale)}>
          <span class="category-badge">{post.category}</span>
          <time datetime={post.date}>{post.date}</time>
          <h3>{post.title}</h3>
          <p>{post.description}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
