---
import RecipeCard from "@/components/RecipeCard.astro";
import { recipePageCopy } from "@/data/recipePages";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { recipes } from "@/data/recipes";

const copy = recipePageCopy.ja;
---

<BaseLayout title={copy.title} description={copy.description} canonicalPath="/ja/recipes/" locale="ja" routeKey="/recipes/">
  <section class="content-section">
    <div class="section-heading">
      <p class="eyebrow">{copy.eyebrow}</p>
      <h1>{copy.h1}</h1>
      <p class="lead">{copy.lead}</p>
    </div>
    <div class="recipe-grid">
      {recipes.map((recipe) => <RecipeCard recipe={recipe} locale="ja" />)}
    </div>
  </section>
</BaseLayout>
