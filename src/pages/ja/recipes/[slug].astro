---
import PromptBlock from "@/components/PromptBlock.astro";
import PromptCartButton from "@/components/PromptCartButton.astro";
import PromptFragmentCard from "@/components/PromptFragmentCard.astro";
import RecipeCard from "@/components/RecipeCard.astro";
import { categoryLabel, localizedRecipe, recipePageCopy } from "@/data/recipePages";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getRecipe, recipes } from "@/data/recipes";

export function getStaticPaths() {
  return recipes.map((recipe) => ({ params: { slug: recipe.slug }, props: { recipe } }));
}

const { recipe } = Astro.props;
const related = recipe.relatedRecipes.map((slug) => getRecipe(slug)).filter(Boolean);
const copy = recipePageCopy.ja;
const pageRecipe = localizedRecipe(recipe, "ja");
---

<BaseLayout title={pageRecipe.title} description={pageRecipe.shortDescription} canonicalPath={`/ja/recipes/${recipe.slug}/`} image={recipe.image} locale="ja" routeKey="/recipes/">
  <article class="content-section">
    <div class="section-heading">
      <p class="eyebrow">{categoryLabel(recipe.category, "ja")}レシピ</p>
      <h1>{pageRecipe.title}</h1>
      <p class="lead">{pageRecipe.description}</p>
      <div class="card-actions">
        <PromptCartButton fragment={{ id: `${recipe.slug}-full-positive`, category: "subject", label: `${pageRecipe.title} full positive prompt`, text: recipe.positivePrompt, sourceRecipeSlug: recipe.slug, sourceRecipeTitle: recipe.title }} label={copy.addFull} />
      </div>
    </div>
    <div class="detail-grid">
      <div>
        <PromptBlock title={copy.positive} text={recipe.positivePrompt} copyLabel={copy.copy} />
        <PromptBlock title={copy.negative} text={recipe.negativePrompt} copyLabel={copy.copy} />
        <PromptBlock title={copy.parameters} text={recipe.parameters} copyLabel={copy.copy} />
      </div>
      <aside class="hero-panel">
        <h2>{copy.modelNotes}</h2>
        <p>{pageRecipe.modelNotes}</p>
        <h3>{copy.suitableUses}</h3>
        <ul>{pageRecipe.suitableUses.map((item) => <li>{item}</li>)}</ul>
      </aside>
    </div>
  </article>

  <section class="content-section">
    <div class="section-heading">
      <h2>{copy.breakdown}</h2>
      <p class="muted">{copy.breakdownLead}</p>
    </div>
    <div class="feature-grid">
      {recipe.breakdown.map((fragment) => <PromptFragmentCard fragment={fragment} locale="ja" addLabel={copy.addToCart} sourceLabel={copy.source} />)}
    </div>
  </section>

  <section class="content-section">
    <h2>{copy.variations}</h2>
    <div class="feature-grid">
      {recipe.variations.map((fragment) => <PromptFragmentCard fragment={fragment} locale="ja" addLabel={copy.addToCart} sourceLabel={copy.source} />)}
    </div>
  </section>

  <section class="content-section article-body">
    <h2>{copy.commonMistakes}</h2>
    <ul>{pageRecipe.commonMistakes.map((mistake) => <li>{mistake}</li>)}</ul>
  </section>

  <section class="content-section">
    <h2>{copy.related}</h2>
    <div class="recipe-grid">
      {related.map((item) => item && <RecipeCard recipe={item} locale="ja" />)}
    </div>
  </section>
</BaseLayout>
