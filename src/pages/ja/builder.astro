---
import PromptBuilder from "@/components/PromptBuilder.tsx";
import { builderCopy } from "@/data/i18n";
import BaseLayout from "@/layouts/BaseLayout.astro";

const copy = builderCopy.ja;
---

<BaseLayout title={copy.title} description={copy.description} canonicalPath="/ja/builder/" locale="ja" routeKey="/builder/">
  <PromptBuilder client:load locale="ja" />
  <section class="content-section article-body">
    <h2>{copy.howTitle}</h2>
    <p>{copy.p1}</p>
    <p>{copy.p2}</p>
  </section>
</BaseLayout>
