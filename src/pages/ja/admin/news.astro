---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="ニュース管理"
  description="Smart Prompt App のニュース編集入口。"
  canonicalPath="/ja/admin/news/"
  showPromptCart={false}
  robots="noindex,nofollow"
  locale="ja"
  routeKey="/admin/news/"
>
  <section class="hero admin-hero">
    <div>
      <p class="eyebrow">ローカル管理</p>
      <h1>ニュース更新デスク</h1>
      <p class="lead">サイト管理者向けのニュース編集入口です。本文は自分で日本語や中国語にできますが、編集フォームは統一 JSON を作りやすい英語構造です。</p>
      <div class="hero-actions">
        <a class="button" href="/ja/news/">ニュースを見る</a>
        <a class="button secondary" href="/admin/news/">完全な編集画面を開く</a>
      </div>
    </div>
  </section>
  <section class="content-section">
    <iframe class="admin-embed" src="/admin/news/" title="News admin editor"></iframe>
  </section>
</BaseLayout>
