---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { staticPageCopy } from "@/data/staticPages";

const copy = staticPageCopy.privacy.ja;
---

<BaseLayout title={copy.title} description={copy.description} canonicalPath="/ja/privacy/" locale="ja" routeKey="/privacy/">
  <article class="content-section article-body">
    <h1>{copy.h1}</h1>
    {copy.body.map((paragraph) => <p>{paragraph}</p>)}
  </article>
</BaseLayout>
