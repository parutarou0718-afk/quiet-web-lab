---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { siteTools } from "@/data/tools";

const groups = ["Text Tools", "Image Tools", "Document Tools", "Automation Tools"] as const;
---

<BaseLayout title="AI Tools for Workflows, Prompts, Documents, and Automation" description="A practical AI tools overview for text prompts, image prompt building, document workflows, and automation templates." canonicalPath="/tools/" locale="en" routeKey="/tools/">
  <section class="content-section">
    <div class="section-heading">
      <p class="eyebrow">Tools</p>
      <h1>AI tools for repeatable work, not one-off experiments.</h1>
      <p class="lead">Use available tools now, and follow planned tools that will expand the site into text, image, document, and automation workflows.</p>
    </div>
  </section>

  {groups.map((group) => (
    <section class="content-section tool-category-section">
      <div class="section-heading">
        <h2>{group}</h2>
      </div>
      <div class="article-grid">
        {siteTools.filter((tool) => tool.category === group).map((tool) => (
          <a class="article-card article-card--action" href={tool.url}>
            <span class={tool.status === "Available" ? "category-badge" : "category-badge category-badge--soon"}>{tool.status}</span>
            <h3>{tool.title}</h3>
            <p>{tool.description}</p>
            <p><strong>Use cases:</strong> {tool.useCases.join(", ")}</p>
          </a>
        ))}
      </div>
    </section>
  ))}
</BaseLayout>
